<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.schroneko.dotfiles-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/username/ghq/github.com/schroneko/dotfiles/scripts/dotfiles-sync.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/Users/username/Library/Logs/dotfiles-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/username/Library/Logs/dotfiles-sync.log</string>
</dict>
</plist>
